{
  "expo": {
    "name": "SmartFieldSurvey",
    "slug": "SmartFieldSurvey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "smartfieldsurvey",
    "splash": {
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow SmartFieldSurvey to access your camera",
        "NSContactsUsageDescription": "Allow SmartFieldSurvey to access your contacts",
        "NSLocationWhenInUseUsageDescription": "Allow SmartFieldSurvey to access your location"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_CONTACTS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-contacts",
      "expo-location"
    ]
  }
}
